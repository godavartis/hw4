<% if @current_user %>
  <h1>New Entry</h1>

  <form action="/entries" method="post" enctype="multipart/form-data">
    <input type="hidden" name="place_id" value="<%= params["place_id"] %>">

    <p>
      <label for="title_input">Title</label>
      <input type="text" name="title" id="title_input" class="form-control">
    </p>

    <p>
      <label for="description_input">Description</label>
      <textarea name="description" id="description_input" class="form-control" rows="5"></textarea>
    </p>

    <p>
      <label for="occurred_on_input">Occurred On</label>
      <input type="date" name="occurred_on" id="occurred_on_input" class="form-control">
    </p>

    <p>
      <label for="uploaded_image_input">Image (optional)</label>
      <input type="file" name="uploaded_image" id="uploaded_image_input" class="form-control" accept="image/png, image/jpg, image/jpeg, image/gif">
    </p>

    <button class="btn btn-primary">Save Entry</button>
  </form>

  <p class="mt-3"><a href="/places/<%= params["place_id"] %>" class="btn btn-secondary">Back to Place</a></p>
<% else %>
  <p>You must be <a href="/login" class="btn btn-primary btn-sm">logged in</a> to add entries.</p>
<% end %>